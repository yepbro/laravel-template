{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": [
        "laravel",
        "framework"
    ],
    "license": "MIT",
    "require": {
        "php": "8.5.*",
        "ext-pdo": "*",
        "bacon/bacon-qr-code": "^3.1",
        "dragon-code/laravel-deploy-operations": "^7.1",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.45",
        "laravel/passkeys": "^0.1.0",
        "laravel/tinker": "^3.0",
        "pragmarx/google2fa": "^9.0",
        "tpetry/laravel-postgresql-enhanced": "^3.5"
    },
    "require-dev": {
        "brianium/paratest": "^7.8",
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel-lang/lang": "^15.29",
        "laravel/boost": "^2.0",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.28",
        "laravel/sail": "^1.41",
        "laravel/telescope": "^5.18",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "back": [
            "@pint",
            "@phpstan"
        ],
        "front": [
            "@prettier",
            "@eslint"
        ],
        "max": [
            "@min",
            "@tests"
        ],
        "min": [
            "@back",
            "@front"
        ],
        "pint": "./vendor/bin/pint -v",
        "pint-show": "./vendor/bin/pint --test",
        "phpstan": "./vendor/bin/phpstan analyse",
        "tests": "@php artisan test -p",
        "prettier": "npm run format",
        "eslint": "npm run lint:fix",
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "dev:spa": [
            "@php -r \"echo PHP_EOL.'Vue-only SPA: http://localhost/spa'.PHP_EOL.PHP_EOL;\"",
            "@dev"
        ],
        "dev:islands": [
            "@php -r \"echo PHP_EOL.'Blade + Vue islands: http://localhost/islands'.PHP_EOL.PHP_EOL;\"",
            "@dev"
        ],
        "open:spa": "npm run open:spa",
        "open:islands": "npm run open:islands",
        "front:test:unit": "npm run test:unit",
        "front:test:e2e": "npm run test:e2e",
        "front:msw:init": "npm run msw:init",
        "test": [
            "@php artisan config:clear --ansi",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan boost:update --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "laravel/telescope"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
