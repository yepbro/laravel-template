{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "dev:spa": "vite",
        "devtools": "vue-devtools",
        "format": "prettier --write resources/ tests/ package.json vite.config.js vitest.config.ts playwright.config.ts eslint.config.js tsconfig.json tailwind.config.js components.json .prettierrc README.md docs/",
        "format:check": "prettier --check resources/ tests/ package.json vite.config.js vitest.config.ts playwright.config.ts eslint.config.js tsconfig.json tailwind.config.js components.json .prettierrc README.md docs/",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "msw:init": "msw init public --save",
        "open:spa": "node scripts/open-mode.mjs spa",
        "test:e2e": "playwright test",
        "test:e2e:headed": "playwright test --headed",
        "test:e2e:ui": "playwright test --ui",
        "test:unit": "vitest run",
        "test:unit:coverage": "vitest run --coverage",
        "test:unit:watch": "vitest",
        "typecheck": "vue-tsc --noEmit",
        "ci:frontend": "npm run format:check && npm run lint && npm run typecheck && npm run build && npm run test:unit:coverage",
        "audit:high": "npm audit --audit-level=high"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/devtools": "^8.1.0",
        "@vue/eslint-config-typescript": "^14.3.0",
        "@vue/test-utils": "^2.4.6",
        "@vitest/coverage-v8": "^4.1.5",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-vue": "^9.32.0",
        "jsdom": "^29.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "msw": "^2.12.14",
        "playwright": "^1.58.2",
        "prettier": "^3.4.2",
        "prettier-plugin-organize-imports": "^4.1.0",
        "prettier-plugin-tailwindcss": "^0.6.11",
        "shadcn-vue": "^2.4.3",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.23.0",
        "vite": "^7.0.7",
        "vitest": "^4.1.0",
        "vue-tsc": "^2.2.4"
    },
    "dependencies": {
        "@formkit/auto-animate": "^0.9.0",
        "@internationalized/date": "^3.12.0",
        "@laravel/passkeys": "^0.1.0",
        "@tanstack/vue-query": "^5.92.12",
        "@tanstack/vue-table": "^8.21.3",
        "@unhead/vue": "^2.1.12",
        "@unovis/vue": "^1.6.4",
        "@vee-validate/zod": "^4.15.1",
        "@vueuse/core": "^14.2.1",
        "@vueuse/integrations": "^14.2.1",
        "@vueuse/motion": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cropperjs": "^1.6.2",
        "embla-carousel-vue": "^8.6.0",
        "lucide-vue-next": "^0.577.0",
        "maska": "^3.2.0",
        "pinia": "^3.0.4",
        "pinia-plugin-persistedstate": "^4.7.1",
        "reka-ui": "^2.9.2",
        "tailwind-merge": "^3.5.0",
        "vaul-vue": "^0.4.1",
        "vee-validate": "^4.15.1",
        "vue": "^3.5.30",
        "vue-draggable-plus": "^0.6.1",
        "vue-i18n": "^11.3.0",
        "vue-input-otp": "^0.3.2",
        "vue-picture-cropper": "^1.0.0",
        "vue-router": "^5.0.4",
        "vue-sonner": "^2.0.9",
        "vue3-dropzone": "^2.2.1",
        "zod": "^3.25.76"
    },
    "overrides": {
        "electron": ">=39.8.5"
    },
    "msw": {
        "workerDirectory": [
            "public"
        ]
    }
}
