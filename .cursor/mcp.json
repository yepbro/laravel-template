{
    "mcpServers": {
        "laravel-boost": {
            "command": "vendor/bin/sail",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "shadcnVue": {
            "command": "npx",
            "args": [
                "shadcn-vue@latest",
                "mcp"
            ]
        }
    }
}